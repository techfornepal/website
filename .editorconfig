# EditorConfig - Universal editor settings
# Works with VS Code, Cursor, Vim, Neovim, Sublime, Atom, etc.

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

[*.{js,jsx,ts,tsx,json,css,scss,html,xml,yml,yaml}]
indent_style = space
indent_size = 2

[*.{md,mdx}]
trim_trailing_whitespace = false
max_line_length = 80

[*.json]
max_line_length = 120

[package.json]
max_line_length = 200

[Makefile]
indent_style = tab
